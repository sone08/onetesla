<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- CarPlay entitlement — required for all CarPlay apps -->
    <!-- Request this from Apple at: https://developer.apple.com/contact/carplay/ -->
    <key>com.apple.developer.carplay-information-app</key>
    <true/>

    <!-- Audio / Navigation entitlements (add if needed later) -->
    <!-- <key>com.apple.developer.carplay-navigation</key> -->
    <!-- <true/> -->

    <!-- Standard entitlements -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
